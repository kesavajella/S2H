class Solution {
    public int numIdenticalPairs(int[] nums) {
        HashMap<Integer,Integer> s=new HashMap<Integer,Integer>();
        int count=0;
        for(int num:nums) {
            int freq=s.getOrDefault(num,0);
            count+=freq;
            s.put(num,freq+1);
        }
        return count;
    }
}
