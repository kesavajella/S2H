class Solution {
    public int thirdMax(int[] nums) {
        long max=Long.MIN_VALUE;
        long smax=Long.MIN_VALUE;
        long tmax=Long.MIN_VALUE;
        for(int val:nums) {
            long n=val;
            if(n==max || n==smax || n==tmax) {
                continue;
            } if(n>max) {
                tmax=smax;
                smax=max;
                max=n;
            } else if(n>smax) {
                tmax=smax;
                smax=n;
            } else if(n>tmax){
                tmax=n;
            }
        }
        return (tmax==Long.MIN_VALUE)?(int)max:(int)tmax;
    }
}
