class Solution {
    public boolean isPalindrome(int x) {
        int s=0,t;
        t=x;
        while(x>0) {
            int r=x%10;
            s=s*10+r;
            x/=10;
        }
        if(s==t && t>=0) {
            return true;
        }
        else {
            return false;
        }
    }
}
